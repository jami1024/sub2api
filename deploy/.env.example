# =============================================================================
# Sub2API Docker Environment Configuration
# =============================================================================
# cp .env.example .env && nano .env
# docker-compose up -d
#
# 只需设置与默认值不同的项，其余可删除。
# =============================================================================

# -----------------------------------------------------------------------------
# Server
# -----------------------------------------------------------------------------
BIND_HOST=0.0.0.0
SERVER_PORT=8080
# release / debug
SERVER_MODE=release
# standard: 完整 SaaS 功能；simple: 隐藏 SaaS 功能并跳过计费
RUN_MODE=standard
TZ=Asia/Shanghai

# -----------------------------------------------------------------------------
# PostgreSQL（必填）
# -----------------------------------------------------------------------------
POSTGRES_USER=sub2api
POSTGRES_PASSWORD=change_this_secure_password
POSTGRES_DB=sub2api

# 连接池（可选，以下为默认值）
DATABASE_MAX_OPEN_CONNS=50
DATABASE_MAX_IDLE_CONNS=10
DATABASE_CONN_MAX_LIFETIME_MINUTES=30
DATABASE_CONN_MAX_IDLE_TIME_MINUTES=5

# -----------------------------------------------------------------------------
# Redis
# -----------------------------------------------------------------------------
# 留空表示无密码
REDIS_PASSWORD=
REDIS_DB=0
REDIS_POOL_SIZE=1024
REDIS_MIN_IDLE_CONNS=10
REDIS_ENABLE_TLS=false

# -----------------------------------------------------------------------------
# Admin 账号（首次启动自动创建）
# -----------------------------------------------------------------------------
ADMIN_EMAIL=admin@sub2api.local
# 留空则自动生成，首次启动日志中显示
ADMIN_PASSWORD=

# -----------------------------------------------------------------------------
# JWT
# -----------------------------------------------------------------------------
# 留空每次重启随机生成（所有用户会被登出）
# 生成方式: openssl rand -hex 32
JWT_SECRET=
JWT_EXPIRE_HOUR=24

# -----------------------------------------------------------------------------
# TOTP (2FA)
# -----------------------------------------------------------------------------
# 留空每次重启随机生成（已有 TOTP 配置会失效）
# 生成方式: openssl rand -hex 32
TOTP_ENCRYPTION_KEY=

# -----------------------------------------------------------------------------
# Security
# -----------------------------------------------------------------------------
SECURITY_URL_ALLOWLIST_ENABLED=false
# 关闭白名单时是否允许 http://（默认仅 https）
SECURITY_URL_ALLOWLIST_ALLOW_INSECURE_HTTP=false
# 是否允许私有 IP 作为上游地址
SECURITY_URL_ALLOWLIST_ALLOW_PRIVATE_HOSTS=false
# 白名单启用时的上游主机列表（逗号分隔）
# SECURITY_URL_ALLOWLIST_UPSTREAM_HOSTS=

# -----------------------------------------------------------------------------
# Gemini OAuth（可选，仅 Gemini 账号需要）
# -----------------------------------------------------------------------------
# 两种模式：
# 1. Code Assist OAuth — 需要 GCP project_id，可用内置客户端（留空即可）
# 2. AI Studio OAuth — 需自建 OAuth Client，设置下方 ID/Secret
#    指南: https://ai.google.dev/gemini-api/docs/oauth
#    注意: OAuth Client 须发布为 Production，Testing 模式 token 7 天过期
GEMINI_OAUTH_CLIENT_ID=
GEMINI_OAUTH_CLIENT_SECRET=
GEMINI_OAUTH_SCOPES=
# 本地配额模拟 JSON（Code Assist only）
# GEMINI_QUOTA_POLICY=

# 内置 OAuth client_secret（可选，不在代码中内置）
# GEMINI_CLI_OAUTH_CLIENT_SECRET=
# ANTIGRAVITY_OAUTH_CLIENT_SECRET=
# ANTIGRAVITY_USER_AGENT_VERSION=

# -----------------------------------------------------------------------------
# 图片生成（可选）
# -----------------------------------------------------------------------------
# 流式上游数据间隔超时（秒），0 禁用，范围 60-1800
GATEWAY_IMAGE_STREAM_DATA_INTERVAL_TIMEOUT=900
# 流式 keepalive 间隔（秒），0 禁用，范围 5-60
GATEWAY_IMAGE_STREAM_KEEPALIVE_INTERVAL=10
# 进程级图片并发限制
GATEWAY_IMAGE_CONCURRENCY_ENABLED=false
GATEWAY_IMAGE_CONCURRENCY_MAX_CONCURRENT_REQUESTS=0
# reject: 直接 429；wait: 等待空闲槽位
GATEWAY_IMAGE_CONCURRENCY_OVERFLOW_MODE=reject
GATEWAY_IMAGE_CONCURRENCY_WAIT_TIMEOUT_SECONDS=30
GATEWAY_IMAGE_CONCURRENCY_MAX_WAITING_REQUESTS=100

# -----------------------------------------------------------------------------
# 代理（可选）
# -----------------------------------------------------------------------------
# 用于访问 GitHub（在线更新 + 定价数据）
# 支持: http / https / socks5 / socks5h
# UPDATE_PROXY_URL=
